#!/usr/bin/env zsh
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "$0")" && pwd)"
BLENDER_APP="${BLENDER_APP:-Blender}"

BLEND_FILES=(
	"$SCRIPT_DIR/blender/level/level.blend"
	"$SCRIPT_DIR/blender/models/props.blend"
)

for file in "${BLEND_FILES[@]}"; do
	if [[ ! -f "$file" ]]; then
		echo "Missing Blender file: $file" >&2
		exit 1
	fi

	echo "Opening $file"
	open -n -a "$BLENDER_APP" -- "$file"
done
